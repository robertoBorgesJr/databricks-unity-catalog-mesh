		dataType: dateTime
		formatString: General Date
		lineageTag: c159cbf7-3cb8-4c98-b201-5b66fa4970f5
		summarizeBy: none
		sourceColumn: dh_processamento_gold

		variation Variation
			isDefault
			relationship: 2625bfc4-17ab-4f96-a939-78eb71ba74dc
			defaultHierarchy: LocalDateTable_9c14d399-f5a0-4b40-b9b6-ccb6afd1b614.'Hierarquia de datas'

		annotation SummarizationSetBy = Automatic

	column Tipo_Operacao =
			
			SWITCH(
			    TRUE(),
			    -- Lista de CFOPs comuns de devolução/anulação
			    dim_cfop[cfop_codigo] IN {1201, 1202, 2201, 2202, 5201, 5202, 6201, 6202}, "Devoluções / Deduções",
			    -- Remessas e Bonificações que não geram receita financeira real
			    dim_cfop[cfop_codigo] IN {5910, 6910, 5911, 6911}, "Bonificação / Brinde",
			    -- Padrão para vendas comerciais
			    "Faturamento de Vendas" )
		lineageTag: 29d605cf-eda0-4c5d-947d-98d28669c171
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column Tipo_Mercado =
			
			VAR PrimeiroDigito = LEFT(FORMAT(dim_cfop[cfop_codigo], "0"), 1)
			RETURN
			    SWITCH(
			        PrimeiroDigito,
			        "5", "Mercado Interno (Estadual)",
			        "6", "Mercado Externo (Interestadual)",
			        "7", "Exportação",
			        "Outros"
			    )
		lineageTag: 05cc27e7-2632-44ce-869a-88cf89e4baf7
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

